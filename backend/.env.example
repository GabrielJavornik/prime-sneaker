# Configuracao do Servidor
PORT=3000
NODE_ENV=development
APP_TIMEZONE=America/Sao_Paulo

# Seguranca HTTP
# Em producao, informe apenas as origens reais do seu frontend.
# Nao use * nem null.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# /api-docs nunca e exposto em NODE_ENV=production, mesmo se essa flag estiver true.
ENABLE_API_DOCS=false

# Configuracao do banco PostgreSQL hospedado no Neon
DB_HOST=ep-seu-projeto-pooler.regiao.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=sua_senha_do_neon
DB_NAME=neondb
DB_SSL=true

# Seguranca - JWT
JWT_SECRET=troque_por_uma_chave_aleatoria_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# Basic Auth legado: mantenha desativado e use Bearer JWT no painel admin.
# Mesmo se habilitado, o backend so aceita Basic Auth em NODE_ENV=development/test/local.
# Em producao, ENABLE_BASIC_AUTH=true faz o servidor falhar ao iniciar.
# Se precisar habilitar em ambiente local controlado, use ADMIN_PASS forte com 16+ caracteres.
ENABLE_BASIC_AUTH=false
ADMIN_USER=
ADMIN_PASS=

# Superadmin inicial do painel
# Use para criar/promover o dono do painel com npm run init-db ou npm run migrate
SEED_SUPERADMIN_NAME=Super Administrador
SEED_SUPERADMIN_EMAIL=admin@exemplo.com
SEED_SUPERADMIN_PASSWORD=troque_por_uma_senha_forte_do_superadmin

# Pix
# Informe a chave real apenas no seu .env local/servidor. Nao versionar chave real.
PIX_KEY=sua_chave_pix_aqui
PIX_MERCHANT_NAME=PRIME SNEAKER
PIX_MERCHANT_CITY=ERECHIM

# URLs e envio de email
APP_URL=http://localhost:3000
EMAIL_USER=seu_email
EMAIL_PASS=sua_senha_de_aplicativo
